# Unity as a Library (T4.4) — unityLibrary/ + shared/ are wholesale regenerated by
# Unity's "Export Project" + tool/reintegrate-unity.ps1 (~4GB: IL2CPP intermediates,
# compiled .so, build cache). Not source of truth — that's the Unity project repo.
# The actual reproducible bits (reintegration script + patched aar) live in tool/,
# which IS tracked. See memory: uaal-entry-point-status.
/unityLibrary/
/shared/

# Remember to never publicly share your keystore.
# See https://flutter.dev/to/reference-keystore
key.properties
**/*.keystore
**/*.jks
